# Local dev defaults to SQLite. On Railway, DATABASE_URL is injected automatically
# when you attach a Postgres plugin.
DATABASE_URL=sqlite:///./calibrate.db

# Signs session cookies. Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# If unset, a random key is used and all sessions reset on every restart.
SECRET_KEY=

# USDA FoodData Central API key (free): https://fdc.nal.usda.gov/api-key-signup.html
# Without it, food lookups still work via Open Food Facts; USDA fallback is skipped.
FDC_API_KEY=
